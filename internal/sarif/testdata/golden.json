{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "sieve",
          "version": "v0.2.0",
          "informationUri": "https://github.com/gnanam1990/sieve",
          "rules": [
            {
              "id": "sieve/bug",
              "name": "sieve/bug",
              "shortDescription": {
                "text": "Bug issue"
              },
              "fullDescription": {
                "text": "Findings categorized as bug"
              },
              "properties": {
                "tags": [
                  "bug"
                ]
              }
            },
            {
              "id": "sieve/style",
              "name": "sieve/style",
              "shortDescription": {
                "text": "Style issue"
              },
              "fullDescription": {
                "text": "Findings categorized as style"
              },
              "properties": {
                "tags": [
                  "style"
                ]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "sieve/bug",
          "level": "error",
          "message": {
            "text": "Unchecked error from scanner",
            "markdown": "**Unchecked error from scanner**\n\nscanner.Err() is ignored."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.go"
                },
                "region": {
                  "startLine": 7,
                  "endLine": 9
                }
              }
            }
          ],
          "fingerprints": {
            "sieveFingerprint": "abc123"
          },
          "properties": {
            "category": "bug",
            "confidence": 0.88,
            "repeated": false,
            "severity": "major",
            "side": "RIGHT",
            "tier": "inline"
          }
        },
        {
          "ruleId": "sieve/style",
          "level": "note",
          "message": {
            "text": "Short variable name",
            "markdown": "**Short variable name**\n\nUse a clearer name."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.go"
                },
                "region": {
                  "startLine": 12,
                  "endLine": 12
                }
              }
            }
          ],
          "fingerprints": {
            "sieveFingerprint": "def456"
          },
          "properties": {
            "category": "style",
            "confidence": 0.65,
            "repeated": true,
            "severity": "nit",
            "side": "RIGHT",
            "tier": "notes"
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "main.go"
          }
        }
      ]
    }
  ]
}
